# NearBuy Backend – Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Supabase PostgreSQL (get from Supabase → Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT Secrets (generate strong random strings — use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET=your_super_secret_access_key_here_change_me
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_change_me

# Gmail SMTP (use App Password, not your real password)
# 1. Enable 2FA on Gmail
# 2. Go to Google Account → Security → App Passwords
# 3. Create one and paste it here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_gmail_app_password_16_chars

# Google OAuth (get from Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
